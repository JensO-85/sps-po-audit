generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  buyPlans    BuyPlan[]
  poUploads   PoUpload[]
  comparisons Comparison[]
}

model BuyPlan {
  id           String    @id @default(cuid())
  filename     String
  parsedData   Json?
  uploadedAt   DateTime  @default(now())
  deletedAt    DateTime?
  uploadedById String
  uploadedBy   User      @relation(fields: [uploadedById], references: [id])

  comparisons Comparison[]
}

model PoUpload {
  id           String   @id @default(cuid())
  filename     String
  parsedData   Json?
  uploadedAt   DateTime @default(now())
  uploadedById String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])

  comparisonLinks ComparisonPoUpload[]
}

model Comparison {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  buyPlanId   String
  buyPlan     BuyPlan  @relation(fields: [buyPlanId], references: [id])

  poUploadLinks ComparisonPoUpload[]
  items         ComparisonItem[]
}

// Join table: a comparison can reference multiple PO uploads
model ComparisonPoUpload {
  comparisonId String
  poUploadId   String
  comparison   Comparison @relation(fields: [comparisonId], references: [id])
  poUpload     PoUpload   @relation(fields: [poUploadId], references: [id])

  @@id([comparisonId, poUploadId])
}

model ComparisonItem {
  id            String     @id @default(cuid())
  comparisonId  String
  sku           String
  isUnmatched   Boolean    @default(false)
  poData        Json?
  buyPlanData   Json?
  discrepancies Json?
  comparison    Comparison @relation(fields: [comparisonId], references: [id])

  @@index([comparisonId])
  @@index([sku])
}
